# ======================
# Shniro AI Solver - Environment Variables
# ======================
# Copy this file to .env and fill in your real keys.
# NEVER commit the .env file to git.

PORT=3000

# --- AI API Keys ---
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here
TOGETHER_API_KEY=your_together_api_key_here

# --- Database ---
MONGODB_URI=mongodb://username:password@host:port/shniro_solver

# --- Auth ---
JWT_SECRET=your_strong_random_secret_here

# --- Admin ---
# Comma-separated emails that can open the analytics dashboard.
# If this is empty, only a user with username "admin" is treated as admin.
ADMIN_EMAILS=admin@example.com

# --- Supabase (optional / unused) ---
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your_supabase_anon_key
# SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
